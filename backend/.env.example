# Copy to .env and fill the keys (DO NOT commit real secrets)
# Notion OAuth
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=http://localhost:3000/api/auth/notion/callback

# Notion integration / database
NOTION_ACCESS_TOKEN=
NOTION_DATABASE_ID=

# OpenAI (used for embeddings / LLM)
OPENAI_API_KEY=

# Other
PORT=3000
INGEST_SECRET=

# Admin UI
# Access admin UI at http://localhost:3000/api/admin/ui
